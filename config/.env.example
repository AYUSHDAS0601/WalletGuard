# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-change-in-production
LOG_LEVEL=INFO

# ── Blockchain APIs ──────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key
ALCHEMY_API_KEY=your_alchemy_api_key
INFURA_PROJECT_ID=your_infura_project_id
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/${INFURA_PROJECT_ID}

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── TimescaleDB / PostgreSQL ─────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=blockchain_anomaly
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/blockchain_anomaly

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=blockchain_alerts

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TRANSACTION_TOPIC=ethereum-transactions
KAFKA_ALERT_TOPIC=anomaly-alerts

# ── ML Models ────────────────────────────────────────────────────────────────
MODEL_CHECKPOINT_DIR=./checkpoints
GNN_MODEL_PATH=./checkpoints/gnn_best.pth
BILSTM_MODEL_PATH=./checkpoints/bilstm_best.pth
XGBOOST_MODEL_PATH=./checkpoints/xgboost_model.json
GNN_IN_CHANNELS=64
GNN_HIDDEN_CHANNELS=128
GNN_OUT_CHANNELS=32
BILSTM_INPUT_SIZE=50
BILSTM_HIDDEN_SIZE=128

# ── Detection Thresholds ─────────────────────────────────────────────────────
ANOMALY_SCORE_THRESHOLD=0.7
HIGH_RISK_THRESHOLD=0.85
WASH_TRADE_CYCLE_DEPTH=5
FLASH_LOAN_MIN_PROTOCOLS=2
COORDINATED_WALLET_TIME_WINDOW_MINUTES=30
